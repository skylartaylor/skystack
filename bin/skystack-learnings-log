#!/usr/bin/env bash
# skystack-learnings-log — append a learning to the project learnings file
# Usage: skystack-learnings-log '{"skill":"review","type":"pitfall","key":"n-plus-one","insight":"...","confidence":8,"source":"observed"}'
#
# Append-only storage. Duplicates (same key+type) are resolved at read time
# by skystack-learnings-search ("latest winner" per key+type).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/skystack-slug" 2>/dev/null)"
SKYSTACK_HOME="${SKYSTACK_HOME:-$HOME/.skystack}"
mkdir -p "$SKYSTACK_HOME/projects/$SLUG"

INPUT="$1"

# Validate: input must be parseable JSON
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  echo "skystack-learnings-log: invalid JSON, skipping" >&2
  exit 1
fi

# Inject timestamp if not present
if ! printf '%s' "$INPUT" | bun -e "const j=JSON.parse(await Bun.stdin.text()); if(!j.ts) process.exit(1)" 2>/dev/null; then
  INPUT=$(printf '%s' "$INPUT" | bun -e "
    const j = JSON.parse(await Bun.stdin.text());
    j.ts = new Date().toISOString();
    console.log(JSON.stringify(j));
  " 2>/dev/null) || true
fi

echo "$INPUT" >> "$SKYSTACK_HOME/projects/$SLUG/learnings.jsonl"
